    </div>
    <div id="devices" hx-get="/htmx/devices" hx-trigger="load, every 30s" class="space-y-3">
      <div class="text-slate-400">Loading…</div>
    </div>
  </section>

  <section>
    <h2 class="text-lg font-semibold mb-3">Top blocked (24h)</h2>
    <div id="top-blocked" hx-get="/htmx/top-blocked" hx-trigger="load, every 60s"
