def cmd_serve(cfg: Config, args):
    try:
        from fastapi import FastAPI, Request, Form
        from fastapi.responses import HTMLResponse, Response
        import uvicorn
    except ImportError:
        sys.stderr.write(
            "ERR: fastapi + uvicorn required for `nosey serve`.\n"
            "  Install: pip install 'fastapi[standard]' uvicorn\n"
        )
        return 2

    app = FastAPI(title="Nosey", docs_url=None, redoc_url=None)

    # cached backend (refresh login on auth failures)
    _state: dict = {"backend": None, "last_login": 0.0}

    def get_backend() -> Optional[PiholeBackend]:
        now = time.time()
        if _state["backend"] is None or (now - _state["last_login"]) > 300:
            try:
                b = make_backend(cfg)
                if not isinstance(b, PiholeBackend):
                    return None
                b.login()
                _state["backend"] = b
                _state["last_login"] = now
            except Exception as e:
                sys.stderr.write(f"backend error: {e}\n")
                return None
        return _state["backend"]

    def esc(s: Any) -> str:
        import html as _h
        return _h.escape(str(s) if s is not None else "")

    @app.get("/", response_class=HTMLResponse)
    def index():
        return WEB_HTML

    @app.get("/htmx/status", response_class=HTMLResponse)
    def htmx_status():
        b = get_backend()
        if b is None:
            return '<span class="text-red-600">● Pi-hole: unreachable</span>'
        return (f'<span class="text-emerald-600">● Pi-hole: '
                f'<span class="font-mono">{esc(b.base)}</span></span>')

    @app.get("/htmx/stats", response_class=HTMLResponse)
    def htmx_stats():
        b = get_backend()
        if b is None:
            return '<div class="col-span-4 text-red-600 bg-white p-4 rounded">Cannot reach Pi-hole API</div>'
        try:
            summary = b.stats_summary()
        except Exception as e:
            return f'<div class="col-span-4 text-red-600 bg-white p-4 rounded">{esc(e)}</div>'

        q = summary.get("queries", {}) or summary
        total = q.get("total") or q.get("dns_queries_today") or 0
        blocked = q.get("blocked") or q.get("ads_blocked_today") or 0
        pct = (blocked / total * 100) if total else 0.0
        clients = q.get("active_clients") or q.get("unique_clients") or 0
        upstreams = q.get("forwarded") or 0

        cards = [
            ("Queries", f"{total:,}", "text-slate-700"),
            ("Blocked", f"{blocked:,}", "text-red-600"),
            ("Block rate", f"{pct:.1f}%", "text-amber-600"),
            ("Active clients", str(clients), "text-emerald-600"),
        ]
        html_ = ""
        for label, val, cls in cards:
            html_ += (f'<div class="bg-white p-4 rounded shadow-sm">'
                      f'<div class="text-xs uppercase text-slate-400">{esc(label)}</div>'
                      f'<div class="text-2xl font-semibold {cls}">{esc(val)}</div></div>')
        return html_

    @app.get("/htmx/top-blocked", response_class=HTMLResponse)
    def htmx_top_blocked():
        b = get_backend()
        if b is None:
            return '<div class="p-3 text-red-600">Pi-hole unreachable</div>'
        rows = b.top_domains(n=12, blocked=True)
        if not rows:
            return '<div class="p-3 text-slate-400">No blocked queries yet.</div>'
        out = ""
        for r in rows:
            dom = r.get("domain") or r.get("name") or "?"
            n = r.get("count") or r.get("hits") or 0
            out += (f'<div class="flex justify-between p-2 px-3">'
                    f'<span class="font-mono text-xs truncate">{esc(dom)}</span>'
                    f'<span class="text-slate-500 text-xs ml-2">{n:,}</span></div>')
        return out

    @app.get("/htmx/devices", response_class=HTMLResponse)
    def htmx_devices():
        devs = load_registry(cfg)
        b = get_backend()
        client_stats = {}
        if b:
            try:
                for c in b.top_clients(n=50, blocked=False):
                    ip = c.get("ip") or c.get("name") or ""
                    client_stats.setdefault(ip, {})["total"] = c.get("count") or 0
                for c in b.top_clients(n=50, blocked=True):
                    ip = c.get("ip") or c.get("name") or ""
                    client_stats.setdefault(ip, {})["blocked"] = c.get("count") or 0
            except Exception:
                pass

        if not devs:
            return ('<div class="bg-white rounded p-6 text-center text-slate-500">'
                    'Registry empty. Run <code>nosey wizard</code> to add a device.</div>')
        out = ""
        for name, d in devs.items():
            cs = client_stats.get(d.ip or "", {})
            qtot = cs.get("total", 0)
            qbl = cs.get("blocked", 0)
            pct = (qbl / qtot * 100) if qtot else 0.0
            badge = ('<span class="text-emerald-700 bg-emerald-100 px-2 py-0.5 rounded text-xs">enabled</span>'
                     if d.enabled else
                     '<span class="text-slate-500 bg-slate-100 px-2 py-0.5 rounded text-xs">disabled</span>')
            tpl_badge = (f'<span class="bg-indigo-100 text-indigo-700 px-2 py-0.5 rounded text-xs font-mono">{esc(d.template)}</span>'
                         if d.template else '<span class="text-slate-400 text-xs">no template</span>')
            consent_warn = ""
            if d.owner not in cfg.self_owners and not d.consent_doc:
                consent_warn = '<span class="text-amber-700 bg-amber-100 px-2 py-0.5 rounded text-xs">⚠ no consent_doc</span>'
            out += f"""
<div class="bg-white rounded shadow-sm p-4">
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0">
      <div class="flex items-center gap-2 flex-wrap">
        <h3 class="font-semibold">{esc(name)}</h3>
        {badge}
        {tpl_badge}
        {consent_warn}
        <span class="text-xs text-slate-400">owner: {esc(d.owner)}</span>
      </div>
      <div class="text-xs text-slate-500 mt-1 font-mono">
        {esc(d.ip or '?')} · {esc(d.mac or 'no mac')} · {esc(d.routing)}
      </div>
      <div class="text-xs text-slate-600 mt-2">
        24h: <b>{qtot:,}</b> queries · <b class="text-red-600">{qbl:,}</b> blocked ({pct:.1f}%)
      </div>
    </div>
    <div class="flex flex-col gap-1 shrink-0">
      <button class="text-xs px-3 py-1 rounded bg-slate-700 text-white hover:bg-slate-900"
              hx-post="/htmx/device/{esc(name)}/toggle" hx-target="#devices">
        {'Disable' if d.enabled else 'Enable'}
      </button>
      <button class="text-xs px-3 py-1 rounded bg-indigo-600 text-white hover:bg-indigo-800
              {'opacity-30 cursor-not-allowed' if not d.template else ''}"
              {'disabled' if not d.template else ''}
              hx-get="/htmx/device/{esc(name)}/diff" hx-target="#modal-content">
        Template diff
      </button>
    </div>
  </div>
</div>"""
        return out

    @app.post("/htmx/device/{name}/toggle", response_class=HTMLResponse)
    def htmx_toggle(name: str):
        devs = load_registry(cfg)
        if name not in devs:
            return Response(status_code=404)
        d = devs[name]
        if not d.enabled and d.owner not in cfg.self_owners and not d.consent_doc:
            return ('<div class="bg-amber-50 border border-amber-300 p-3 rounded text-amber-900">'
                    f'⛔ <b>{esc(name)}</b> requires <code>consent_doc</code> before enabling. '
                    'See <code>CONTRIBUTING.md → consent</code>.</div>')
        d.enabled = not d.enabled
        save_registry(cfg, devs)
        return htmx_devices()

    @app.get("/htmx/device/{name}/diff", response_class=HTMLResponse)
    def htmx_diff(name: str):
        devs = load_registry(cfg)
        if name not in devs or not devs[name].template:
            return Response(status_code=404)
        d = devs[name]
        b = get_backend()
        if b is None:
            return '<div class="p-6 text-red-600">Pi-hole unreachable</div>'

        gid = d.dns_group_id
        if gid is None:
            try:
                gid = b.ensure_group(d.dns_group or name, comment=f"nosey: {name}")
                d.dns_group_id = gid
                save_registry(cfg, devs)
            except Exception as e:
                return f'<div class="p-6 text-red-600">Could not ensure group: {esc(e)}</div>'

        tpl = load_template(cfg, d.template)
        entries = template_entries(tpl)
        try:
            diff = diff_template_vs_pihole(b, gid, entries)
        except Exception as e:
            return f'<div class="p-6 text-red-600">Diff failed: {esc(e)}</div>'

        def row_add(e):
            kind = "regex" if e["is_regex"] else "exact"
            return (f'<tr class="border-t border-slate-100">'
                    f'<td class="p-2 text-green-700">+</td>'
                    f'<td class="p-2"><span class="tier-{e["tier"]} px-1.5 rounded text-xs">T{e["tier"]}</span></td>'
                    f'<td class="p-2 font-mono text-xs">{esc(e["value"])}</td>'
                    f'<td class="p-2 text-xs text-slate-500">{esc(kind)}</td>'
                    f'<td class="p-2 text-xs">{esc(e.get("why_block",""))}<br>'
                    f'<span class="text-slate-400">breaks: {esc(e.get("breaks_if_blocked","-"))}</span></td>'
                    f'</tr>')

        def row_remove(r):
            return (f'<tr class="border-t border-slate-100">'
                    f'<td class="p-2 text-red-700">−</td><td></td>'
                    f'<td class="p-2 font-mono text-xs">{esc(r.get("domain"))}</td>'
                    f'<td class="p-2 text-xs text-slate-500">{esc(r.get("kind",""))}</td>'
                    f'<td class="p-2 text-xs text-slate-500">currently in group (nosey-managed)</td>'
                    f'</tr>')

        adds_html = "".join(row_add(e) for e in diff["add"]) or '<tr><td colspan="5" class="p-3 text-slate-400 text-center">Nothing new to add — group is up to date.</td></tr>'
        rems_html = "".join(row_remove(r) for r in diff["remove"]) or ""
        rem_section = ""
        if rems_html:
            rem_section = (
                '<h4 class="font-semibold mt-4 mb-1 text-red-700">To remove '
                f'({len(diff["remove"])})</h4>'
                '<table class="w-full text-sm"><tbody>' + rems_html + '</tbody></table>'
            )
        return f"""
<div class="p-6">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-bold">Apply <code>{esc(d.template)}</code> → <code>{esc(name)}</code></h2>
    <button onclick="document.getElementById('modal').classList.add('hidden')"
            class="text-slate-400 hover:text-slate-700">✕</button>
  </div>
  <div class="text-sm text-slate-600 mb-3">
    Group: <code>{esc(d.dns_group or name)}</code> (id={gid}) · device: <code>{esc(d.ip or '?')}</code>
  </div>
  <div class="flex gap-4 text-sm mb-3">
    <span class="text-green-700">+ {len(diff["add"])} to add</span>
    <span class="text-red-700">− {len(diff["remove"])} to remove</span>
    <span class="text-slate-500">= {len(diff["keep"])} already in group</span>
  </div>
  <h4 class="font-semibold mb-1 text-green-700">To add ({len(diff["add"])})</h4>
  <table class="w-full text-sm">
    <thead><tr class="text-xs text-slate-500 text-left"><th></th><th>Tier</th><th>Domain</th><th>Kind</th><th>Reason</th></tr></thead>
    <tbody>{adds_html}</tbody>
  </table>
  {rem_section}
  <div class="mt-6 flex justify-end gap-2">
    <button onclick="document.getElementById('modal').classList.add('hidden')"
            class="px-4 py-2 rounded bg-slate-200 hover:bg-slate-300 text-sm">Cancel</button>
    <button hx-post="/htmx/device/{esc(name)}/apply"
            hx-target="#modal-content" hx-swap="innerHTML"
            class="px-4 py-2 rounded bg-indigo-600 text-white hover:bg-indigo-800 text-sm">
      Confirm — push {len(diff["add"])+len(diff["remove"])} change(s) to Pi-hole
    </button>
  </div>
</div>"""

    @app.post("/htmx/device/{name}/apply", response_class=HTMLResponse)
    def htmx_apply(name: str):
        devs = load_registry(cfg)
        if name not in devs or not devs[name].template:
            return Response(status_code=404)
        d = devs[name]
        b = get_backend()
        if b is None:
            return '<div class="p-6 text-red-600">Pi-hole unreachable</div>'

        gid = d.dns_group_id or b.ensure_group(d.dns_group or name, comment=f"nosey: {name}")
        d.dns_group_id = gid
        if d.ip:
            try:
                b.ensure_client(d.ip, gid, comment=f"nosey: {name}")
            except Exception:
                pass

        tpl = load_template(cfg, d.template)
        entries = template_entries(tpl)
        diff = diff_template_vs_pihole(b, gid, entries)

        added = 0
        failed_add = 0
        for e in diff["add"]:
            ok = b.add_domain(e["value"], deny=True, regex=e["is_regex"],
                              groups=[gid], comment=f"nosey:{d.template}")
            if ok: added += 1
            else: failed_add += 1
        removed = 0
        for r in diff["remove"]:
            ok = b.remove_domain(r["domain"], deny=True, regex=(r.get("kind") == "regex"))
            if ok: removed += 1

        save_registry(cfg, devs)
        resp = Response(
            content=f"""
<div class="p-6">
  <h2 class="text-lg font-bold mb-3 text-emerald-700">✓ Applied</h2>
  <ul class="text-sm space-y-1 text-slate-700">
    <li>Group: <code>{esc(d.dns_group)}</code> (id={gid})</li>
    <li>Client <code>{esc(d.ip or '?')}</code> attached</li>
    <li><b class="text-green-700">{added}</b> domain(s) added{f' · <b class="text-red-700">{failed_add}</b> failed' if failed_add else ''}</li>
    <li><b class="text-red-700">{removed}</b> domain(s) removed</li>
  </ul>
  <div class="mt-4 text-right">
    <button onclick="document.getElementById('modal').classList.add('hidden')"
            class="px-4 py-2 rounded bg-slate-200 hover:bg-slate-300 text-sm">Close</button>
  </div>
</div>""",
            media_type="text/html",
        )
        resp.headers["HX-Close-Modal"] = "1"
        return resp

    print(f"nosey serve — http://{args.host}:{args.port}")
    print(f"  pi-hole api: {cfg.dns_backend.get('api_url', '(unset)')}")
    print(f"  registry:    {cfg.registry_path}")
    print(f"  Open the URL above in your browser. Ctrl+C to stop.\n")
    uvicorn.run(app, host=args.host, port=args.port, log_level="warning")


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def main():
    cfg = Config.load()

    p = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("list", help="show registry").set_defaults(func=cmd_list)

    a = sub.add_parser("add", help="add device")
    a.add_argument("name")
    a.add_argument("--ip"); a.add_argument("--mac")
    a.add_argument("--owner", required=True)
    a.add_argument("--routing", default="gateway-manual", choices=["gateway-manual", "wireguard"])
    a.add_argument("--template", help="template name from templates/")
    a.add_argument("--consent-doc", dest="consent_doc")
    a.add_argument("--notes", default="")
    a.set_defaults(func=cmd_add)

    e = sub.add_parser("enable", help="enable device (consent check)")
    e.add_argument("name")
    e.add_argument("--force", action="store_true", help="bypass consent check (auditable)")
    e.set_defaults(func=cmd_enable)

    d = sub.add_parser("disable", help="disable device")
    d.add_argument("name")
    d.set_defaults(func=cmd_disable)

    sub.add_parser("apply", help="sync DNS backend + print instructions").set_defaults(func=cmd_apply)

    s = sub.add_parser("status", help="health check")
    s.add_argument("name", nargs="?")
    s.set_defaults(func=cmd_status)

    disc = sub.add_parser("discover", help="nmap LAN + suggest devices")
    disc.add_argument("--subnet", default="192.168.0.0/24")
    disc.set_defaults(func=cmd_discover)

    w = sub.add_parser("wizard", help="interactive add")
    w.add_argument("--subnet", default="192.168.0.0/24")
    w.set_defaults(func=cmd_wizard)

    sv = sub.add_parser("serve", help="web UI bridge (FastAPI + HTMX)")
    sv.add_argument("--host", default="127.0.0.1")
    sv.add_argument("--port", type=int, default=8765)
    sv.set_defaults(func=cmd_serve)

    cap = sub.add_parser("capture", help="passive forensic report from Zeek logs (no MITM)")
    cap.add_argument("name", help="device name in registry")
    cap.add_argument("--window", type=int, default=30, help="minutes to analyze (default 30)")
    cap.add_argument("--out", help="write report to file instead of stdout")
    cap.set_defaults(func=cmd_capture)

    args = p.parse_args()
    sys.exit(args.func(cfg, args) or 0)


if __name__ == "__main__":
    main()
